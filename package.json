    "@angular/router": "^22.0.4",
    "@tailwindcss/postcss": "^4.3.2",
    "postcss": "^8.5.16",
    "rxjs": "~7.8.0",
    "tailwindcss": "^4.3.2",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
